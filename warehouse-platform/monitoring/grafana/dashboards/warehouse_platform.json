{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Warehouse Platform Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.2" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "heatmap", "name": "Heatmap", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
        "enable": true,
        "expr": "changes(warehouse_alerts_open_total{severity=\"critical\"}[2m]) > 0",
        "hide": false,
        "iconColor": "red",
        "name": "Critical Alerts",
        "step": "60s",
        "titleFormat": "Critical Alert",
        "type": "alert"
      }
    ]
  },
  "description": "Comprehensive overview of the Autonomous Warehouse Inventory Audit Platform — service health, ingestion pipeline, robot fleet, and inventory accuracy.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": true,
      "title": "Kafka UI",
      "tooltip": "Open Kafka UI",
      "type": "link",
      "url": "http://localhost:8090"
    },
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": true,
      "title": "API Docs",
      "tooltip": "Open API documentation",
      "type": "link",
      "url": "http://localhost:8001/docs"
    }
  ],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🏭 Service Health",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
      "description": "Live up/down status for each platform microservice. Green = healthy, Red = down.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" }, "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "up{job=\"topology-service\"}",
          "instant": true,
          "legendFormat": "Topology Service",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "up{job=\"mission-service\"}",
          "instant": true,
          "legendFormat": "Mission Service",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "up{job=\"observation-service\"}",
          "instant": true,
          "legendFormat": "Observation Service",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "up{job=\"reconciliation-service\"}",
          "instant": true,
          "legendFormat": "Reconciliation Service",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "up{job=\"alerting-service\"}",
          "instant": true,
          "legendFormat": "Alerting Service",
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "up{job=\"digital-twin-sync\"}",
          "instant": true,
          "legendFormat": "Digital Twin Sync",
          "refId": "F"
        }
      ],
      "title": "Panel 1 — Service Health Status",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "📦 Ingestion Pipeline",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
      "description": "Rate of observations processed by the observation-service per minute.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "observations / min",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 3,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "sum(rate(warehouse_observations_processed_total[1m])) * 60",
          "legendFormat": "Observations/min (all robots)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "sum by (warehouse_id) (rate(warehouse_observations_processed_total[1m])) * 60",
          "legendFormat": "Warehouse {{ warehouse_id }}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "sum(rate(warehouse_observations_failed_total[1m])) * 60",
          "legendFormat": "Failed observations/min",
          "refId": "C"
        }
      ],
      "title": "Panel 2 — Observation Ingestion Rate (obs/min)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
      "description": "Current Kafka consumer group lag across all warehouse topics. High lag indicates consumers are falling behind.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "neutral": 0 },
          "mappings": [],
          "min": 0,
          "max": 10000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "orange", "value": 3000 },
              { "color": "red", "value": 5000 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 3,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "sum(kafka_consumer_group_lag{topic=\"observation.raw\"})",
          "instant": true,
          "legendFormat": "observation.raw",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "sum(kafka_consumer_group_lag{topic=\"inventory.reconciliation.mismatch\"})",
          "instant": true,
          "legendFormat": "reconciliation.mismatch",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "sum(kafka_consumer_group_lag{topic=\"robot.telemetry.heartbeat\"})",
          "instant": true,
          "legendFormat": "robot.telemetry",
          "refId": "C"
        }
      ],
      "title": "Panel 3 — Kafka Consumer Lag (per topic)",
      "type": "gauge"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "🤖 Robot Fleet & Missions",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
      "description": "Number of robots that have sent a heartbeat within the last 60 seconds.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 15 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "count(warehouse_robot_last_heartbeat_timestamp_seconds > (time() - 60))",
          "instant": false,
          "legendFormat": "Active Robots",
          "refId": "A"
        }
      ],
      "title": "Panel 4 — Active Robots Count",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
      "description": "Number of missions currently in each state.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Active Missions" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Completed (1h)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Failed (1h)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 15 },
      "id": 40,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "warehouse_missions_active_total",
          "instant": true,
          "legendFormat": "Active Missions",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "increase(warehouse_missions_completed_total[1h])",
          "instant": true,
          "legendFormat": "Completed (1h)",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "increase(warehouse_missions_failed_total[1h])",
          "instant": true,
          "legendFormat": "Failed (1h)",
          "refId": "C"
        }
      ],
      "title": "Mission Counts",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
      "description": "Rate of alerts fired grouped by severity level as a stacked bar chart.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisColorMode": "text",
            "axisLabel": "alerts / min",
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1,
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "warning" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "high" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "info" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 5,
      "options": {
        "barRadius": 0,
        "barWidth": 0.97,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "auto",
        "stacking": "normal",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "sum by (severity) (rate(warehouse_alerts_fired_total[1m])) * 60",
          "legendFormat": "{{ severity }}",
          "refId": "A"
        }
      ],
      "title": "Panel 5 — Alert Rate by Severity (stacked)",
      "type": "barchart"
    },

    {
      "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
      "description": "Mission completion rate over time (completed / (completed + failed)).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "completion rate",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "decimals": 1,
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["mean", "min", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "sum(rate(warehouse_missions_completed_total[5m])) / (sum(rate(warehouse_missions_completed_total[5m])) + sum(rate(warehouse_missions_failed_total[5m])))",
          "legendFormat": "Mission Completion Rate",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "sum(rate(warehouse_missions_completed_total[5m]))",
          "legendFormat": "Completions/s",
          "refId": "B"
        }
      ],
      "title": "Panel 7 — Mission Completion Rate",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "📊 Inventory Accuracy & Reconciliation",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
      "description": "Overall inventory accuracy percentage — ratio of correct scans to total observations over the last 30 minutes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 98 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 28 },
      "id": 6,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "pluginVersion": "10.4.2",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "(1 - (sum(rate(warehouse_inventory_mismatches_total[30m])) / sum(rate(warehouse_observations_processed_total[30m])))) * 100",
          "instant": false,
          "legendFormat": "Inventory Accuracy %",
          "refId": "A"
        }
      ],
      "title": "Panel 6 — Inventory Accuracy %",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
      "description": "Inventory mismatch events per minute over time by mismatch type.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisColorMode": "text",
            "axisLabel": "mismatches / min",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 3,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 28 },
      "id": 41,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "sum by (mismatch_type) (rate(warehouse_inventory_mismatches_total[1m])) * 60",
          "legendFormat": "{{ mismatch_type }}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
          "expr": "sum(rate(warehouse_inventory_mismatches_total[1m])) * 60",
          "legendFormat": "Total mismatches/min",
          "refId": "B"
        }
      ],
      "title": "Mismatch Rate by Type",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 104,
      "title": "⚡ Performance & Latency",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "warehouse-prometheus" },
      "description": "HTTP request duration p95 heatmap per service. Darker cells = more requests at that latency bucket.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "scheme" },
          "custom": {
            "fillOpacity": 80,
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "scaleDistribution": { "log": 2, "type": "log" }
          },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 37 },
      "id": 8,
      "options": {
        "calculate": false,
        "cellGap": 2,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "min": 0,
          "mode": "scheme",
